{
  "name": "paperli-advertisement",
  "version": "1.0.0",
  "description": "Remotion video advertisement for Paperli - AI-powered research paper analyzer",
  "scripts": {
    "start": "remotion preview index.ts",
    "build": "remotion render index.ts PaperliAdvertisement output.mp4",
    "build-hd": "remotion render index.ts PaperliAdvertisement output-4k.mp4 --props '{\"fps\": 30}'",
    "still": "remotion still index.ts PaperliAdvertisement still.png"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.427",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
